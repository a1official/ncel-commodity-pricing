# ============================================================================
# COMMODITY INTELLIGENCE PLATFORM - ENVIRONMENT CONFIGURATION
# ============================================================================

# Copy this file to .env and fill in your actual API keys

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/commodity_db
SQLALCHEMY_ECHO=False

# ============================================================================
# API KEYS - DATA SOURCES
# ============================================================================

# data.gov.in - AGMARKNET API
# Register at: https://data.gov.in
DATA_GOV_API_KEY=your_data_gov_key_here

# USDA QuickStats API
# Register at: https://quickstats.nass.usda.gov/api
USDA_API_KEY=your_usda_api_key_here

# FAO Food Price Index
# API Documentation: https://www.fao.org/webservices/foodpriceindex
FAO_API_KEY=optional_fao_key

# APEDA Export Statistics
# API Documentation: https://apeda.gov.in
APEDA_API_KEY=optional_apeda_key

# MPEDA Marine Export Statistics
# API Documentation: https://mpeda.gov.in
MPEDA_API_KEY=optional_mpeda_key

# ============================================================================
# FASTAPI CONFIGURATION
# ============================================================================
PROJECT_NAME=NCEL Commodity Intelligence Platform
API_V1_STR=/api/v1
DEBUG=False

# ============================================================================
# PREFECT CONFIGURATION (Data Ingestion Pipeline)
# ============================================================================
PREFECT_API_URL=http://localhost:4200/api
PREFECT_HOME=/home/ubuntu/.prefect

# ============================================================================
# REDIS CONFIGURATION (Optional - for caching)
# ============================================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================================
# FORECASTING CONFIGURATION
# ============================================================================
FORECAST_LOOKBACK_WEEKS=52
FORECAST_CONFIDENCE_THRESHOLD=70
LSTM_EPOCHS=20
XGBOOST_N_ESTIMATORS=100

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# ============================================================================
# COMMODITY CATEGORIES (21 Commodities)
# ============================================================================
# Grains: Rice, Wheat, Maize, Millets
# Spices: Turmeric, Chilli, Cumin
# Vegetables: Onion, Tomato, Potato
# Fruits: Banana, Grapes, Pineapple
# Marine: Shrimp, Mackerel, Tuna, Trout
# Cash Crops: Soybean, Sugar, Cotton, Groundnut
